# ============================================================
# CryptoApp Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Lines starting with # are comments. Remove the # to enable.
# ============================================================


# ----------------------------------------------------------
# REQUIRED — the app won't do much without these
# ----------------------------------------------------------

# CoinMarketCap API key (free tier works)
# Get one at: https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=

# Google API key — powers the Gemini agents (orchestrator, trading agent)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=


# ----------------------------------------------------------
# TRADING — required if you want live trading
# ----------------------------------------------------------

# Coinbase API credentials
# Generate at: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_API_SECRET=

# KuCoin API credentials (for low-cap coins Coinbase doesn't list)
# Generate at: https://www.kucoin.com/account/api
# KUCOIN_API_KEY=
# KUCOIN_API_SECRET=
# KUCOIN_PASSPHRASE=

# Daily trading budget in GBP (default: £0.05)
DAILY_TRADE_BUDGET_GBP=0.05

# Your server URL — used in email approve/reject links
# Change this to your Pi's domain/IP when deployed
TRADE_SERVER_URL=http://localhost:5001

# Email to receive trade approval requests (REQUIRED for trading)
TRADE_NOTIFICATION_EMAIL=


# ----------------------------------------------------------
# EMAIL (SMTP) — required for trade approval emails
# ----------------------------------------------------------

# Gmail SMTP (default). Use an App Password, not your real password.
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Weekly report email addresses (optional)
# REPORT_EMAIL_FROM=
# REPORT_EMAIL_TO=


# ----------------------------------------------------------
# FLASK & SERVER
# ----------------------------------------------------------

# Flask secret key — used for session signing & CSRF tokens
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Host and port (defaults: 127.0.0.1:5001)
# Only change HOST to 0.0.0.0 if running behind a reverse proxy (nginx)
# HOST=127.0.0.1
# PORT=5001

# Enable Flask debug mode (NEVER in production)
# DEBUG=false


# ----------------------------------------------------------
# OPTIONAL
# ----------------------------------------------------------

# DeepSeek API key — used for sentiment analysis agent
# DEEPSEEK_API_KEY=

# Auto-shutdown after idle period (default: true, 5 min timeout)
# Useful on the Pi to save resources
# AUTO_SHUTDOWN=true

# Daily scan time for automated trading loop (24h format, default: 12:00)
# SCAN_TIME=12:00

# Logging level (default: INFO)
# LOG_LEVEL=INFO
