# ============================================================
# CryptoApp Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Lines starting with # are comments. Remove the # to enable.
# ============================================================


# ----------------------------------------------------------
# REQUIRED — the app won't do much without these
# ----------------------------------------------------------

# CoinGecko API key — optional, but raises rate limit from ~10 to 30 req/min
# Free Demo API key at: https://www.coingecko.com/en/api
# Leave blank to use the public endpoint (no key required)
COINGECKO_API_KEY=

# Google API key — powers the Gemini agents (orchestrator, trading agent)
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=


# ----------------------------------------------------------
# FLASK & SERVER
# ----------------------------------------------------------

# Allowed CORS origins — comma-separated (default: http://127.0.0.1:5001)
# On the Pi behind nginx, set to your domain: https://yourdomain.com
# CORS_ORIGINS=http://127.0.0.1:5001

# Enable Flask debug mode (NEVER in production)
# DEBUG=false

# Host and port (defaults: 127.0.0.1:5001)
# Only change HOST to 0.0.0.0 if running behind a reverse proxy (nginx)
# HOST=127.0.0.1
# PORT=5001

# Logging level (default: INFO)
# LOG_LEVEL=INFO

# Flask secret key — used for session signing & CSRF tokens
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# API key for trading endpoints (propose, kill-switch, auto-evaluate)
# Required — all trading POST endpoints check this via Authorization: Bearer <key>
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
TRADING_API_KEY=


# ----------------------------------------------------------
# TRADING — required if you want live trading
# ----------------------------------------------------------

# Daily trading budget in GBP — set to whatever you're comfortable with
DAILY_TRADE_BUDGET_GBP=5.00

# Exchange priority — comma-separated, tried in order (default: kraken)
# EXCHANGE_PRIORITY=kraken

# Kraken API credentials
# Generate at: https://pro.kraken.com/app/settings/api
# Permissions needed: Query Funds, Query/Create/Cancel Orders, Query Ledger
KRAKEN_API_KEY=
KRAKEN_PRIVATE_KEY=

# Bitget API credentials (optional — add bitget to EXCHANGE_PRIORITY to enable)
# Generate at: https://www.bitget.com/account/newApiManagement
# Permissions needed: Trade, Read
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=

# Max single trade as % of daily budget (default: 50)
# MAX_TRADE_PCT=50

# Minimum minutes between trade proposals (default: 60)
# TRADE_COOLDOWN_MIN=60

# Email to receive trade approval requests (REQUIRED for trading)
TRADE_NOTIFICATION_EMAIL=

# Your server URL — used in email approve/reject links
# Change this to your Pi's domain/IP when deployed
# Server URL for email approval links
# Use your Pi's local IP or domain. HTTPS recommended if available.
# Email clients may flag http:// links as insecure.
TRADE_SERVER_URL=http://localhost:5001


# ----------------------------------------------------------
# EMAIL (SMTP) — required for trade approval emails
# ----------------------------------------------------------

# Weekly report email addresses (optional)
# REPORT_EMAIL_FROM=
# REPORT_EMAIL_TO=

# Gmail SMTP (default). Use an App Password, not your real password.
# Generate at: https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
SMTP_PASSWORD=
# SMTP_PORT=587
SMTP_USER=


# ----------------------------------------------------------
# SELL-SIDE CONTROLS
# ----------------------------------------------------------

# Sell automation thresholds (defaults shown)
# SELL_AGENT_RECHECK=true          # Re-analyse holdings with agents
# SELL_RECHECK_HOURS=12            # Hours between agent re-checks per coin
# SELL_MIN_HOLD_HOURS=72.0         # Min hold before any exit fires (except stop-loss)
# SELL_STOP_LOSS_PCT=-50.0         # Full exit — always fires, ignores min hold
# SELL_TRAILING_STOP_PCT=45.0      # Drop-from-peak % for trailing stop
# SELL_TIER1_PCT=75.0              # Tier 1: partial sell at this profit %
# SELL_TIER1_FRACTION=0.33         # Fraction to sell at Tier 1
# SELL_TIER1_TRAILING_PCT=20.0     # Trailing stop tightens to this after Tier 1
# SELL_TIER2_PCT=150.0             # Tier 2: partial sell at this profit %
# SELL_TIER2_FRACTION=0.50         # Fraction of remaining to sell at Tier 2
# SELL_TIER2_TRAILING_PCT=15.0     # Trailing stop tightens to this after Tier 2
# SELL_PROFIT_TARGET_PCT=300.0     # Nuclear full-exit at extreme profit (last resort)

# Auto-approve BUY trades within budget (default: true)
# When true, buys execute immediately without email approval.
# Set to false to require email approval for every buy.
# Sells ALWAYS require manual approval regardless.
BUY_AUTO_APPROVE=true

# Require manual email approval before any sell executes (default: true)
# When true, sells NEVER auto-execute — you must click Approve in the email.
# Set to false if you want sells to auto-execute (not recommended initially).
SELL_REQUIRE_APPROVAL=true



# ----------------------------------------------------------
# OPTIONAL
# ----------------------------------------------------------

# Auto-shutdown after idle period (default: true, 5 min timeout)
# Useful on the Pi to save resources
# AUTO_SHUTDOWN=true

# Cooldown between scans in hours (default: 1)
# SCAN_COOLDOWN_HOURS=1

# Enable/disable the automated scan scheduler (default: true)
# Set to false to disable the daily scan loop
# SCAN_ENABLED=true

# Max coins to analyse per scan (default: 10)
# SCAN_MAX_COINS=10

# Max trade proposals per scan (default: 3)
# SCAN_MAX_PROPOSALS=3

# Minimum gem score to include in scan (default: 5.0)
# SCAN_MIN_GEM_SCORE=5.0

# Daily scan time for automated trading loop (24h format, default: 12:00)
# SCAN_TIME=12:00


# ----------------------------------------------------------
# MARKET MONITOR — lightweight between-scan monitoring
# ----------------------------------------------------------
# Runs price checks, momentum alerts, and quick gem scans between
# deep scans. Uses ONLY cached price data + local ML (no Gemini API).
# Safe for the Pi — negligible CPU, ~96 extra CMC calls/day.

# Enable/disable the market monitor (default: true)
# MONITOR_ENABLED=true

# How often to check held positions vs stop-loss/take-profit (minutes)
# MONITOR_PRICE_INTERVAL_MIN=5

# How often to check for volume spikes & rapid price moves (minutes)
# MONITOR_MOMENTUM_INTERVAL_MIN=15

# How often to run local gem detector on tradeable coins (minutes)
# MONITOR_QUICK_SCAN_INTERVAL_MIN=30

# How often to refresh price data from CoinMarketCap (minutes)
# Keep >= 15 to stay within free-tier limits (~96 calls/day)
# MONITOR_REFRESH_INTERVAL_MIN=15

# Minimum 1h price move (%) to trigger a momentum alert
# MONITOR_RAPID_MOVE_PCT=10

# Volume must exceed average by this % to trigger a spike alert
# MONITOR_VOLUME_SPIKE_PCT=200

# Minutes between repeat alerts for the same coin+type
# MONITOR_ALERT_COOLDOWN_MIN=60

# Max coins to score per quick scan (caps CPU usage on Pi)
# MONITOR_QUICK_SCAN_TOP_N=20

# Minimum gem score to flag in quick scans
# MONITOR_QUICK_SCAN_MIN_GEM=6.0

# ── Opportunistic auto-buy (monitor triggers trades between deep scans) ──
# Enable auto-buy triggers from monitor discoveries (default: true)
# Uses the same trading pipeline, budget cap, and safety rails as deep scans.
# MONITOR_AUTO_BUY=true

# Minimum gem score to trigger a buy analysis (higher bar than quick scan threshold)
# MONITOR_AUTO_BUY_MIN_GEM=7.0

# Minimum agent confidence (0-100) to actually propose the trade
# MONITOR_AUTO_BUY_MIN_CONFIDENCE=55

# Minimum 1h price surge (%) to trigger a momentum-based buy analysis
# MONITOR_AUTO_BUY_MOMENTUM_PCT=15

# Max auto-buy triggers per day (caps API usage + spending)
# MONITOR_AUTO_BUY_MAX_PER_DAY=3


# ----------------------------------------------------------
# AI AGENTS
# ----------------------------------------------------------

# Gemini model for the 3-agent debate orchestrator (bull/bear/referee)
# DEBATE_AGENT_MODEL=gemini-2.0-flash

# High-conviction validator (Option B): run 5-agent chain as second opinion
# when the debate returns conviction >= threshold. Adds ~6 extra Gemini calls
# only on coins the debate is already serious about (typically 0-2 per scan).
# DEBATE_VALIDATOR_ENABLED=true
# DEBATE_VALIDATOR_THRESHOLD=75


# ----------------------------------------------------------
# Q-LEARNING — reinforcement learning from trade outcomes
# ----------------------------------------------------------
# The RL agent adjusts buy confidence scores based on past P&L.
# Defaults are conservative — only change if you understand the impact.

# Learning rate — how much each outcome updates the Q-table (default: 0.15)
# QL_ALPHA=0.15

# Discount factor — weighting of future rewards vs immediate (default: 0.9)
# QL_GAMMA=0.9

# Exploration rate — probability of random action to discover new patterns (default: 0.10)
# QL_EPSILON=0.10

# Minimum exploration rate (floor after decay, default: 0.02)
# QL_EPSILON_MIN=0.02

# Decay per completed trade — epsilon reduces as experience accumulates (default: 0.995)
# QL_EPSILON_DECAY=0.995

# Minimum state visits before Q-learning blocks or adjusts trades (default: 3)
# Prevents a single bad trade from poisoning an entire state class
# QL_MIN_VISITS=3

# Restore epsilon to this floor on restart (useful after a losing streak, default: 0.0)
# QL_EPSILON_FLOOR=0.0


# ----------------------------------------------------------
# ADVANCED TRADING CONTROLS
# ----------------------------------------------------------

# Max price slippage % vs proposal price before order is rejected (default: 3.0)
# MAX_SLIPPAGE_PCT=3.0

# Minimum hours before an agent recheck is triggered by sharp drawdown (default: 4.0)
# SELL_DRAWDOWN_RECHECK_MIN_HOURS=4.0

# Portfolio concentration controls
# How many open positions before requiring extra conviction for new buys (default: 5)
# SCAN_CONCENTRATION_LIMIT=5
# Minimum conviction % required when at/above concentration limit (default: 65)
# SCAN_CONCENTRATION_MIN_CONVICTION=65
